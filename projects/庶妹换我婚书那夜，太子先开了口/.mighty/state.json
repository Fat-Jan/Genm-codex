      "written_at": "2026-03-21T15:00:17Z"
    },
    "10": {
      "chapter": 10,
      "path": "chapters/第010章.md",
      "title": "旧档房里，最先缺的不是卷，是那只手",
      "word_count": 1664,
      "summary": "谢云昭进入东宫旧档房，发现与沈氏副册有关的索引已被人先割走一条。她顺着残卷和索引摸到户部旧账附卷，也第一次确认有人提前在宫中动过这条线。",
      "pov": "谢云昭",
      "location": "东宫旧档房",
      "content_bucket": "宫斗宅斗",
      "tagpack": "恶女",
      "written_at": "2026-03-21T15:00:17Z"
    },
    "11": {
      "chapter": 11,
      "path": "chapters/第011章.md",
      "title": "宋崇的名字，终于从账后面浮了出来",
      "word_count": 2100,
      "summary": "顺着旧档残卷和掌印小吏的口供，谢云昭第一次把顾承州、宋崇与沈氏副册连成了一条官面上的线。她也由此知道，母亲当年碰到的不是一笔账，而是一串人。",
      "pov": "谢云昭",
      "location": "东宫后院茶房",
      "content_bucket": "宫斗宅斗",
      "tagpack": "恶女",
      "written_at": "2026-03-21T15:00:17Z"
    },
    "12": {
      "chapter": 12,
      "path": "chapters/第012章.md",
      "title": "东宫收婚书局，她收的是母亲那口气",
      "word_count": 801,
      "summary": "东宫收婚书局，伯府与顾家第一轮失势，婚书被暂封，旧账并案继续核。谢云昭也第一次在这场局里不再靠婚书站着，而是靠她自己翻出来的账。",
      "pov": "谢云昭",
      "location": "东宫偏殿",
      "content_bucket": "宫斗宅斗",
      "tagpack": "恶女",
      "written_at": "2026-03-21T15:00:17Z"
    },
    "13": {
      "chapter": 13,
      "path": "chapters/第013章.md",
      "title": "她进东宫，不是做客，是来翻账的",
      "word_count": 621,
      "summary": "谢云昭以临时抄录身份进入东宫旧档体系，很快发现有人提前清过与沈氏有关的卷宗。她也开始明白，东宫把她留在这里，不是怜她，而是要她继续往下翻。",
      "pov": "谢云昭",
      "location": "东宫旧档房",
      "content_bucket": "宫斗宅斗",
      "tagpack": "恶女",
      "written_at": "2026-03-21T15:00:17Z"
    },
    "14": {
      "chapter": 14,
      "path": "chapters/第014章.md",
      "title": "灯一灭，动手的人就先露了底",
      "word_count": 416,
      "summary": "旧档房夜里忽然灭灯，有人趁黑摸卷，结果先掉出一块带着“宋”字的木牌。谢云昭没有追人，只先把这只先动的手记了下来。",
      "pov": "谢云昭",
      "location": "东宫旧档房",
      "content_bucket": "宫斗宅斗",
      "tagpack": "恶女",
      "written_at": "2026-03-21T15:00:17Z"
    },
    "15": {
      "chapter": 15,
      "path": "chapters/第015章.md",
      "title": "她拿一个小吏做饵，先钓出宋家一根线",
      "word_count": 282,
      "summary": "谢云昭借掌印小吏做饵，很快在城门前截到宋家跑腿书吏和半张抄单，坐实宋崇与顾承州之间确有私下走账。旧案由婚书与聘银，正式抬到盐引旧账。",
      "pov": "谢云昭",
      "location": "京城城门",
      "content_bucket": "宫斗宅斗",
      "tagpack": "恶女",
      "written_at": "2026-03-21T15:00:17Z"
    },
    "16": {
      "chapter": 16,
      "path": "chapters/第016章.md",
      "title": "顾承州终于开口，可他怕的不是东宫",
      "word_count": 392,
      "summary": "顾承州最终开口，交出旧箱线索，承认自己只是替人跑腿。谢云昭因此确认，京中能翻的差不多已经翻完，真正还没见光的东西已被挪到了外头。",
      "pov": "谢云昭",
      "location": "东宫问话处",
      "content_bucket": "宫斗宅斗",
      "tagpack": "恶女",
      "written_at": "2026-03-21T15:00:17Z"
    },
    "17": {
      "chapter": 17,
      "path": "chapters/第017章.md",
      "title": "出京这一步，她先带走的不是箱，是人",
      "word_count": 290,
      "summary": "离京查箱前，谢云昭先把崔妈妈藏走，又只放一辆空车去河埠。她很快就发现，有人真正想毁的从来不只是箱，而是她手里的活人和证据。",
      "pov": "谢云昭",
      "location": "离京路上",
      "content_bucket": "宫斗宅斗",
      "tagpack": "恶女",
      "written_at": "2026-03-21T15:00:17Z"
    },
    "18": {
      "chapter": 18,
      "path": "chapters/第018章.md",
      "title": "旧箱一开，先掉出来的是药单",
      "word_count": 308,
      "summary": "河埠旧箱一开，先掉出来的不是账，而是一张药单、一页副册残页和几张银票影。药与账终于落在一处，也把沈氏之死和旧账真正并成了一案。",
      "pov": "谢云昭",
      "location": "河埠旧仓",
      "content_bucket": "宫斗宅斗",
      "tagpack": "恶女",
      "written_at": "2026-03-21T15:00:17Z"
    },
    "19": {
      "chapter": 19,
      "path": "chapters/第019章.md",
      "title": "她把假消息放出去，先急的是宫里那只手",
      "word_count": 260,
      "summary": "谢云昭故意放出“旧箱里只有空账”的假消息，当夜便有人闯入旧档房抢药单，反倒先掉出一块宫牌残角。旧案至此不再只是外头两家互吞，而是已经伸进了宫里。",
      "pov": "谢云昭",
      "location": "东宫旧档房",
      "content_bucket": "宫斗宅斗",
      "tagpack": "恶女",
      "written_at": "2026-03-21T15:00:17Z"
    },
    "20": {
      "chapter": 20,
      "path": "chapters/第020章.md",
      "title": "她把第二卷的门推开时，已经没人敢叫她庶女",
      "word_count": 443,
      "summary": "带着顾家旧信、半页实账、副册残页、药单、银票影和宫牌残角再入东宫后，顾家、伯府与宋崇都已被正式压上案桌。谢云昭也第一次不再靠婚书站在门里，而是靠自己把第二卷的大案门推开。",
      "pov": "谢云昭",
      "location": "东宫偏殿外廊",
      "content_bucket": "宫斗宅斗",
