{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "host-capability-matrix-v1.schema.json",
  "title": "Genm Codex Host Capability Matrix v1",
  "type": "object",
  "required": [
    "$schema",
    "version",
    "hosts"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "const": "1.0"
    },
    "hosts": {
      "type": "object",
      "required": [
        "claude",
        "codex",
        "opencode",
        "openclaw",
        "trae"
      ],
      "properties": {
        "claude": {
          "allOf": [
            { "$ref": "#/$defs/host" },
            {
              "properties": {
                "skill_install_root": { "const": "~/.claude/skills" }
              }
            }
          ]
        },
        "codex": {
          "allOf": [
            { "$ref": "#/$defs/host" },
            {
              "properties": {
                "skill_install_root": { "const": "~/.codex/skills" }
              }
            }
          ]
        },
        "opencode": {
          "allOf": [
            { "$ref": "#/$defs/host" },
            {
              "properties": {
                "skill_install_root": { "const": "~/.config/opencode/skills" }
              }
            }
          ]
        },
        "openclaw": {
          "allOf": [
            { "$ref": "#/$defs/host" },
            {
              "properties": {
                "skill_install_root": { "const": "~/.openclaw/skills" }
              }
            }
          ]
        },
        "trae": {
          "allOf": [
            { "$ref": "#/$defs/host" },
            {
              "properties": {
                "skill_install_root": { "const": null }
              }
            }
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "capability_state": {
      "type": "string",
      "enum": [
        "verified",
        "partial",
        "assumed",
        "unsupported"
      ]
    },
    "evidence": {
      "type": "object",
      "required": [
        "kind",
        "ref",
        "summary"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "repo_file",
            "runtime_observation"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "host": {
      "type": "object",
      "required": [
        "status",
        "verification_level",
        "skill_install_root",
        "install_mode",
        "supports_skill_discovery",
        "supports_alias",
        "supports_rules_context",
        "supports_hooks",
        "supports_mcp",
        "supports_native_invocation",
        "degrade_policy",
        "notes",
        "evidence"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "baseline",
            "legacy",
            "experimental",
            "excluded"
          ]
        },
        "verification_level": {
          "type": "string",
          "enum": [
            "verified",
            "partial",
            "assumed"
          ]
        },
        "skill_install_root": {
          "type": [
            "string",
            "null"
          ]
        },
        "install_mode": {
          "type": "string",
          "enum": [
            "symlink",
            "copy",
            "unsupported"
          ]
        },
        "supports_skill_discovery": { "$ref": "#/$defs/capability_state" },
        "supports_alias": { "$ref": "#/$defs/capability_state" },
        "supports_rules_context": { "$ref": "#/$defs/capability_state" },
        "supports_hooks": { "$ref": "#/$defs/capability_state" },
        "supports_mcp": { "$ref": "#/$defs/capability_state" },
        "supports_native_invocation": { "$ref": "#/$defs/capability_state" },
        "degrade_policy": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "install_mode": {
                "const": "unsupported"
              }
            }
          },
          "then": {
            "properties": {
              "skill_install_root": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "install_mode": {
                "enum": [
                  "symlink",
                  "copy"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "skill_install_root": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  }
}
