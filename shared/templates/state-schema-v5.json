{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "state-schema-v5.json",
  "title": "Genm Codex State v5",
  "type": "object",
  "required": ["version", "meta", "progress", "entities", "plot_threads", "knowledge_base"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": ["string", "number"]
    },
    "meta": {
      "type": "object"
    },
    "progress": {
      "type": "object"
    },
    "entities": {
      "type": "object",
      "required": ["characters", "items", "locations"],
      "properties": {
        "characters": {
          "type": "object",
          "required": ["protagonist"],
          "properties": {
            "protagonist": {
              "type": "object",
              "properties": {
                "name": {"type": "string"},
                "location": {
                  "oneOf": [
                    {"type": "string"},
                    {
                      "type": "object",
                      "properties": {
                        "current": {"type": "string"},
                        "origin": {"type": "string"},
                        "previous": {"type": "string"}
                      },
                      "additionalProperties": true
                    }
                  ]
                },
                "inventory": {
                  "type": "array"
                }
              },
              "additionalProperties": true
            },
            "active": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {"type": "string"},
                  "role": {"type": "string"},
                  "relationship": {"type": "string"},
                  "relation_to_protagonist": {"type": "string"}
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        },
        "items": {
          "type": "object",
          "properties": {
            "tracked": {
              "type": "array",
              "items": {
                "oneOf": [
                  {"type": "string"},
                  {
                    "type": "object",
                    "properties": {
                      "name": {"type": "string"}
                    },
                    "required": ["name"],
                    "additionalProperties": true
                  }
                ]
              }
            },
            "protagonist_inventory": {
              "type": "array",
              "items": {
                "oneOf": [
                  {"type": "string"},
                  {
                    "type": "object",
                    "properties": {
                      "name": {"type": "string"}
                    },
                    "required": ["name"],
                    "additionalProperties": true
                  }
                ]
              }
            }
          },
          "additionalProperties": true
        },
        "locations": {
          "type": "object",
          "properties": {
            "current": {"type": "string"},
            "visited": {"type": "array"},
            "important": {"type": "array"}
          },
          "additionalProperties": true
        },
        "factions": {
          "type": "object",
          "properties": {
            "active": {
              "type": "array",
              "items": {
                "oneOf": [
                  {"type": "string"},
                  {
                    "type": "object",
                    "properties": {
                      "name": {"type": "string"}
                    },
                    "required": ["name"],
                    "additionalProperties": true
                  }
                ]
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "plot_threads": {
      "type": "object"
    },
    "knowledge_base": {
      "type": "object",
      "properties": {
        "reader_knows": {"type": "array"},
        "protagonist_knows": {"type": "array"},
        "protagonist_unknown": {"type": "array"},
        "protagonist_doesnt_know": {"type": "array"}
      },
      "additionalProperties": true
    },
    "quality_metrics": {
      "type": "object"
    },
    "auto_learn_config": {
      "type": "object"
    },
    "learned_patterns": {
      "oneOf": [
        {
          "type": "object",
          "not": {
            "required": ["externalized"]
          },
          "required": ["writing_style_preferences"],
          "properties": {
            "writing_style_preferences": {"type": "object"},
            "high_point_preferences": {},
            "avoid_patterns": {},
            "opening_strategy": {},
            "multi_line_guardrails": {},
            "content_standard_alerts": {},
            "recent_guardrails": {
              "type": "object",
              "properties": {
                "must_avoid": {"type": "array"},
                "must_preserve": {"type": "array"},
                "next_chapter_watchpoints": {"type": "array"},
                "expires_after_chapter": {
                  "type": ["integer", "null"]
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["externalized", "sidecar_file"],
          "properties": {
            "externalized": {"const": true},
            "sidecar_file": {"type": "string"},
            "last_updated": {"type": ["string", "null"]},
            "available_sections": {"type": "array"},
            "has_recent_guardrails": {"type": "boolean"},
            "recent_guardrails_expires_after_chapter": {
              "type": ["integer", "null"]
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "market_adjustments": {
      "oneOf": [
        {
          "type": "object",
          "not": {
            "required": ["externalized"]
          },
          "required": ["adjustments"],
          "properties": {
            "last_applied": {"type": ["string", "null"]},
            "source_scan": {},
            "adjustments": {"type": "array"}
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["externalized", "sidecar_file"],
          "properties": {
            "externalized": {"const": true},
            "sidecar_file": {"type": "string"},
            "last_updated": {"type": ["string", "null"]},
            "last_applied": {"type": ["string", "null"]},
            "source_scan": {},
            "adjustment_count": {"type": "integer"}
          },
          "additionalProperties": true
        }
      ]
    },
    "genre_profile": {
      "type": "object",
      "properties": {
        "loaded": {"type": "string"},
        "bucket": {"type": "string"},
        "positioning_initialized": {"type": "boolean"},
        "tagpacks": {"type": "array", "items": {"type": "string"}},
        "strong_tags": {"type": "array", "items": {"type": "string"}},
        "narrative_modes": {"type": "array", "items": {"type": "string"}},
        "tone_guardrails": {"type": "array", "items": {"type": "string"}},
        "positioning_sidecar": {"type": "string"},
        "节奏": {"type": "object"},
        "爽点密度": {"type": ["number", "string"]},
        "strand权重": {"type": "object"},
        "特殊约束": {"type": "array"}
      },
      "additionalProperties": true
    },
    "platform_config": {
      "type": "object"
    },
    "active_launch_grammar": {
      "type": "string"
    },
    "active_primary_pivot": {
      "type": "string"
    },
    "launch_stack_phase": {
      "type": "string"
    },
    "launch_stack_drift_signal": {
      "type": "string"
    },
    "active_context": {
      "type": "object",
      "required": ["sidecar_file"],
      "properties": {
        "sidecar_file": {"type": "string"},
        "last_built": {"type": ["string", "null"]},
        "summary_window": {
          "type": "object",
          "properties": {
            "count": {"type": "integer"},
            "recent_count": {"type": "integer"},
            "latest_chapter": {"type": ["string", "integer", "null"]}
          },
          "additionalProperties": true
        },
        "hook_count": {"type": "integer"},
        "guardrail_count": {"type": "integer"}
      },
      "additionalProperties": true
    },
    "chapter_meta": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "review_score": {"type": ["number", "integer"]},
          "review_grade": {"type": "string"},
          "review_time": {"type": ["string", "null"]},
          "needs_fix": {"type": "boolean"},
          "recommended_next_action": {"type": "string"},
          "issue_clusters": {"type": "array"},
          "dimension_scores": {"type": "object"},
          "chapter_structure": {
            "type": "object",
            "properties": {
              "conflict_type": {
                "type": "string",
                "enum": ["", "resource", "identity", "information", "power", "relationship", "rule", "time", "moral"]
              },
              "protagonist_arc": {
                "type": "string",
                "enum": ["", "suppress", "test", "exchange", "breakthrough", "cost", "revelation", "choice"]
              },
              "opponent_mode": {
                "type": "string",
                "enum": ["", "direct", "indirect", "trap", "test", "alliance", "retreat", "internal"]
              },
              "gain_type": {
                "type": "string",
                "enum": ["", "resource", "information", "relationship", "power", "moral", "none"]
              },
              "cost_visibility": {
                "type": "string",
                "enum": ["", "explicit", "implicit", "delayed", "none"]
              },
              "chapter_end_style": {
                "type": "string",
                "enum": ["", "hook", "residue", "escalation", "revelation", "choice", "payoff", "closure"]
              }
            },
            "additionalProperties": false
          },
          "anti_flattening_flags": {"type": "array"},
          "anti_flattening_summary": {"type": "object"},
          "fanqie_bucket_flags": {"type": "array"},
          "fanqie_bucket_summary": {"type": "object"},
          "content_standard_flags": {"type": "array"},
          "packaging_alignment_note": {"type": "string"},
          "last_close_time": {"type": ["string", "null"]},
          "last_close_route": {"type": "string"},
          "last_close_review_score_before": {"type": ["number", "integer"]},
          "last_close_review_score_after": {"type": ["number", "integer"]}
        },
        "additionalProperties": true
      }
    },
    "chapter_snapshots": {
      "type": "object"
    },
    "summaries_index": {
      "type": "object"
    },
    "character_states": {
      "type": "object"
    },
    "setting_versions": {
      "type": "object"
    },
    "dungeons": {
      "type": "object"
    },
    "teammates": {
      "type": "object"
    },
    "constraints_loaded": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
