{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "research-candidates-v1.schema.json",
  "title": "Genm Codex Research Candidates v1",
  "type": "object",
  "required": ["version", "generated_at", "source_scan", "candidates"],
  "properties": {
    "version": {"type": "string"},
    "generated_at": {"type": "string"},
    "source_scan": {
      "type": "object",
      "required": ["tool", "mode", "report_kind"],
      "properties": {
        "tool": {"type": "string"},
        "mode": {"type": "string"},
        "platform": {"type": "string"},
        "genre": {"type": "string"},
        "depth": {"type": "string"},
        "report_kind": {"type": "string"}
      },
      "additionalProperties": true
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "kind", "source", "confidence", "candidate_files", "evidence_urls", "notes"],
        "properties": {
          "name": {"type": "string"},
          "kind": {"type": "string"},
          "source": {"type": "string"},
          "confidence": {"type": "string"},
          "candidate_files": {"type": "array", "items": {"type": "string"}},
          "evidence_urls": {"type": "array", "items": {"type": "string"}},
          "notes": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
