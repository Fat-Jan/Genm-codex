{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skill-merge-map-v1.schema.json",
  "title": "Genm Codex Skill Merge Map v1",
  "type": "object",
  "required": ["version", "generated_at", "entries"],
  "properties": {
    "version": {"type": "string"},
    "generated_at": {"type": "string"},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["skill", "decision", "reason"],
        "properties": {
          "skill": {"type": "string"},
          "decision": {
            "type": "string",
            "enum": ["merge", "alias", "protected"]
          },
          "target": {"type": "string"},
          "reason": {"type": "string"},
          "notes": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
